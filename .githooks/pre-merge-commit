#!/usr/bin/env bash
# Portable-enforcement-core git-native hook (feat/portable-enforcement-core,
# 2026-07-08). Blocks a non-fast-forward merge landing on main/master unless
# CLAUDE_CONFIRM_MERGE=1 is set. Fast-forward merges create no merge commit
# and never invoke this hook.
#
# Activation is OPT-IN: see .githooks/README.md
# ("git config core.hooksPath .githooks"). Not activated automatically.
#
# Delegates to the shared guard implementations in scripts/enforcement/.
REPO_ROOT="$(git rev-parse --show-toplevel)"
exec python3 "$REPO_ROOT/scripts/enforcement/adapters/git_hook.py" pre-merge-commit
