# ---- Secrets ----
.api_key
.env
.env.*
*.key
*.pem
*.p12
*.crt

# ---- User PII: configs ----
# example.config is the documentation template.
# testuser.config is the committed dummy-user fixture for dev + integration testing.
configs/*.config
!configs/example.config
!configs/testuser.config

# ---- User data: resumes and generated output ----
# resumes/testuser/ is the committed fixture (synthetic Casey Rivera persona).
# output/testuser/ stays gitignored — generated artifacts can be wiped freely.
resumes/*
!resumes/.gitkeep
!resumes/testuser/
!resumes/testuser/**
output/*
!output/.gitkeep

# ---- Persona templates: bundled tracked, user-uploaded gitignored ----
# personas/bundled/*.docx ships with the repo (Phase C).
# personas/{username}/ is per-user PII and stays gitignored.
personas/*
!personas/bundled/
!personas/bundled/**

# ---- LLM telemetry (per-call JSONL emitted by analyzer.py) ----
logs/

# ---- SQLite database (career corpus + candidate memory; per-clone, contains PII) ----
db/*.sqlite
db/*.sqlite-journal
db/*.sqlite-wal
db/*.sqlite-shm

# ---- Eval results and real fixtures (per-clone, may contain real PII) ----
evals/results/*
!evals/results/.gitkeep
# baseline_*.json files are aggregated rubric scores only (no résumé text),
# safe and intended to ship for regression detection per evals/runner.py.
!evals/results/baseline_*.json
evals/fixtures/real/*
!evals/fixtures/real/.gitkeep
# /prompt-tune writes a transient candidate-override file here; never commit it.
evals/_prompt_tune_candidate.json
# /tune-from-annotations writes its transient candidate-override file here too.
evals/_tune_candidate.json

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/
pip-wheel-metadata/

# ---- Tooling caches ----
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ---- OS ----
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Claude Code session files (machine-specific, not project state) ----
.claude/*
!.claude/settings.json
CLAUDE.local.md

# ---- Playwright (β.3) — Chromium binary is ~150MB and lives outside
#       the repo by default (%LOCALAPPDATA%\ms-playwright\). These
#       entries defend against PLAYWRIGHT_BROWSERS_PATH being set to
#       a repo-relative path or `playwright test` default output dirs.
ms-playwright/
playwright-report/
test-results/
.playwright/
