# ---- Secrets ----
.api_key
.env
.env.*
*.key
*.pem
*.p12
*.crt

# ---- User PII: configs (keep only example.config as template) ----
configs/*.config
!configs/example.config

# ---- User data: resumes and generated output ----
resumes/*
!resumes/.gitkeep
output/*
!output/.gitkeep

# ---- LLM telemetry (per-call JSONL emitted by analyzer.py) ----
logs/

# ---- SQLite database (career corpus + candidate memory; per-clone, contains PII) ----
db/*.sqlite
db/*.sqlite-journal
db/*.sqlite-wal
db/*.sqlite-shm

# ---- Eval results and real fixtures (per-clone, may contain real PII) ----
evals/results/*
!evals/results/.gitkeep
evals/fixtures/real/*
!evals/fixtures/real/.gitkeep

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/
pip-wheel-metadata/

# ---- Tooling caches ----
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ---- OS ----
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Claude Code session files (machine-specific, not project state) ----
.claude/*
!.claude/settings.json
CLAUDE.local.md
