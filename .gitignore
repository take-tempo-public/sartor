# ---- Secrets ----
.api_key
.env
.env.*
*.key
*.pem
*.p12
*.crt

# ---- User PII: configs ----
# example.config is the documentation template.
# testuser.config is the committed dummy-user fixture for dev + integration testing.
configs/*.config
!configs/example.config
!configs/testuser.config

# ---- User data: resumes and generated output ----
# resumes/testuser/ is the committed fixture (synthetic Casey Rivera persona).
# output/testuser/ stays gitignored — generated artifacts can be wiped freely.
resumes/*
!resumes/.gitkeep
!resumes/testuser/
!resumes/testuser/**
output/*
!output/.gitkeep

# ---- Persona templates: bundled tracked, user-uploaded gitignored ----
# personas/bundled/*.docx ships with the repo (Phase C).
# personas/cover_letter.html is the shared (persona-agnostic) cover-letter
#   preview shell — repo-shipped, so it's un-ignored alongside the bundled set.
# personas/{username}/ is per-user PII and stays gitignored.
personas/*
!personas/bundled/
!personas/bundled/**
!personas/cover_letter.html

# ---- LLM telemetry (per-call JSONL emitted by analyzer.py) ----
logs/

# ---- SQLite database (career corpus + candidate memory; per-clone, contains PII) ----
db/*.sqlite
db/*.sqlite-journal
db/*.sqlite-wal
db/*.sqlite-shm

# ---- S3 vector-index sidecar (Sprint 7.6; derived + rebuildable: the embedding
#      model + the .npy/.json index). Built by `python -m scripts.build_vector_index`;
#      never committed (rebuildable, ~30MB model) and kept OUT of db/resume.sqlite. ----
db/vector_index/

# ---- Eval results and real fixtures (per-clone, may contain real PII) ----
evals/results/*
!evals/results/.gitkeep
# baseline_*.json files are aggregated rubric scores only (no résumé text),
# safe and intended to ship for regression detection per evals/runner.py.
!evals/results/baseline_*.json
evals/fixtures/real/*
!evals/fixtures/real/.gitkeep
# /prompt-tune writes a transient candidate-override file here; never commit it.
evals/_prompt_tune_candidate.json
# /tune-from-annotations writes its transient candidate-override file here too.
evals/_tune_candidate.json

# ---- Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.venv/
venv/
env/
pip-wheel-metadata/

# ---- Tooling caches ----
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ---- OS ----
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- Claude Code session files (machine-specific, not project state) ----
.claude/*
!.claude/settings.json
CLAUDE.local.md

# ---- Playwright (β.3) — Chromium binary is ~150MB and lives outside
#       the repo by default (%LOCALAPPDATA%\ms-playwright\). These
#       entries defend against PLAYWRIGHT_BROWSERS_PATH being set to
#       a repo-relative path or `playwright test` default output dirs.
ms-playwright/
playwright-report/
test-results/
.playwright/

# ---- docs-site/ (feat/fumadocs-site, v1.0.9 Phase 6) — the Fumadocs
#      (Next.js) app. Its own docs-site/.gitignore covers the standard JS
#      build noise (node_modules/.next/.source/etc.); these repo-root
#      entries exist so the pattern is visible without opening a nested
#      .gitignore, per the deliverable's own ask.
docs-site/node_modules/
docs-site/out/
docs-site/.next/
# docs-site/content/docs/ is FULLY GENERATED by
# scripts/project_docs_to_mdx.py (a build step, run in CI before `npm run
# build` — see .github/workflows/docs-deploy.yml) from the governed L1 doc
# set. Canonical .md stays in-repo; the projected MDX does not — committing
# a derived copy alongside its source would be a second source of truth
# (documentation-architecture.md "Fumadocs sourcing": "the MDX content tree
# is generated/synced"). Run the script locally before `npm run dev`/`build`.
docs-site/content/docs/*.mdx
docs-site/content/docs/meta.json
docs-site/content/docs/screenshots/
!docs-site/content/docs/.gitkeep
# docs-site/openapi.json is FULLY GENERATED by scripts/generate_openapi_spec.py
# (spectree/OpenAPI Layer B Phase 1) — a build artifact, regenerated in CI, not
# a second source of truth for the 5 spectree-decorated routes' schemas.
docs-site/openapi.json
# docs-site/content/docs/api-reference/ is FULLY GENERATED by
# docs-site/scripts/generate-api-docs.mjs (spectree/OpenAPI Layer B Phase 2)
# from docs-site/openapi.json — same "build artifact, not a second source of
# truth" rationale as the L1 projection above. The `*.mdx`/`meta.json`
# top-level rules don't reach this nested subfolder (gitignore `*` doesn't
# cross directory boundaries), hence the separate entry.
docs-site/content/docs/api-reference/
