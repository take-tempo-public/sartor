# Normalize line endings for cross-platform consistency
* text=auto

# Source files — always LF
*.py    text eol=lf
*.md    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.txt   text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Config files — always LF
*.config text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

# Portable git-native hooks — extensionless shell scripts (git's hooksPath
# contract requires the exact names `pre-commit`/`pre-merge-commit`/`pre-push`,
# no `.sh`), so the `*.sh` rule above doesn't catch them. A CRLF-mangled
# shebang line breaks `exec` on POSIX (Linux CI, macOS) and Git for Windows'
# bundled sh alike, so pin LF the same as `*.sh`.
.githooks/pre-commit text eol=lf
.githooks/pre-merge-commit text eol=lf
.githooks/pre-push text eol=lf

# Binary — never diff or mangle
*.docx  binary
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
