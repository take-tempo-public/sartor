{
  "name": "docs-site",
  "version": "0.0.3",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "postinstall": "fumadocs-mdx",
    "gen:api-docs": "node scripts/generate-api-docs.mjs"
  },
  "dependencies": {
    "@orama/orama": "^3.1.18",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.2",
    "fumadocs-mdx": "15.2.0",
    "fumadocs-openapi": "^11.1.1",
    "fumadocs-ui": "npm:@fumadocs/base-ui@16.11.2",
    "lucide-react": "^1.23.0",
    "mermaid": "^11.16.0",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.1"
  },
  "comment:overrides": [
    "next@16.2.10 pins postcss 8.4.31 in its own nested tree, which is affected by",
    "GHSA-qx2v-qp2m-jg93 (moderate: postcss < 8.5.10 fails to escape </style> when",
    "stringifying a CSS AST). Our own top-level postcss is already 8.5.x; this",
    "override lifts the nested copy to the patched line too, so no vulnerable",
    "postcss is installed anywhere in the tree. Remove once Next ships a patched pin."
  ],
  "overrides": {
    "postcss": "^8.5.16"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.16",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3"
  }
}
