{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(python -m ruff check *)",
      "Bash(python -m mypy *)",
      "Bash(python -m pytest)",
      "Bash(python -m pytest *)",
      "Bash(pip show *)",
      "Bash(pip list)",
      "Bash(pip list *)",
      "Bash(where *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude-plugin/hooks/check-plan-approved.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude-plugin/hooks/mark-plan-approved.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude-plugin/hooks/cleanup-plan-on-merge.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
