{
  "description": "Plan-mode workflow hooks for the Resume Optimizer plugin. Steps 4-5 of the OSS migration. Step 5 will add deterministic hooks for security, linting, and route validation.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-plan-approved.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/mark-plan-approved.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cleanup-plan-on-merge.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
